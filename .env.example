# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# Your Anthropic API key — get one at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# Shared passcode for all coaches (any string you choose)
SITE_PASSCODE=your-secret-passcode

# Supabase — server-side (Netlify Functions)
# Found in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Supabase — client-side (browser Realtime)
# Uses the safe anon/public key, NOT the service key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
