# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# Your Anthropic API key — get one at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# Shared passcode for all coaches (any string you choose)
SITE_PASSCODE=your-secret-passcode

# Netlify site ID — found in Site Settings on the Netlify dashboard
# Only needed when running the seed script locally against a deployed site
NETLIFY_SITE_ID=your-site-id
